-- ===== ВКЛАДКА 1: RTTD (ULTRA SKIP) =====
local RttdTab = Window:CreateTab("RTTD", 4483362458)

RttdTab:CreateToggle({
    Name = "Ultra Fast Auto-Skip",
    CurrentValue = false,
    Flag = "SkipToggle",
    Callback = function(Value)
        skip = Value
        if skip then
            refreshSkipRemotes()
            task.spawn(function()
                while skip do
                    for i = 1, #cachedRemotes do
                        local remote = cachedRemotes[i]
                        if remote then
                            if remote:IsA("RemoteEvent") then
                                remote:FireServer()
                                remote:FireServer(true)
                                remote:FireServer("Skip")
                            else
                                task.spawn(function() remote:InvokeServer() end)
                            end
                        end
                    end
                    task.wait(0.01) -- Минимальная задержка против лагов сети
                end
            end)
        end
    end,
})

RttdTab:CreateButton({
    Name = "Refresh Skip Remotes",
    Callback = function()
        refreshSkipRemotes()
        Rayfield:Notify({Title = "System", Content = "События обновлены", Duration = 2})
    end,
})

